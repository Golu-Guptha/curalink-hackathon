# ── Server ─────────────────────────────────────────────────────────────────────
PORT=5000

# ── MongoDB Atlas ──────────────────────────────────────────────────────────────
# Go to: https://cloud.mongodb.com → Create free M0 cluster → Connect → Compass
# Replace <username>, <password>, <cluster>.mongodb.net, <dbname>
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/curalink?retryWrites=true&w=majority

# ── JWT ────────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_YOUR_RANDOM_SECRET_STRING_AT_LEAST_64_CHARS
JWT_EXPIRES_IN=7d

# ── Python AI Engine ───────────────────────────────────────────────────────────
AI_ENGINE_URL=http://127.0.0.1:8000

# ── Frontend URL (for CORS) ────────────────────────────────────────────────────
CLIENT_URL=http://localhost:3000
